# ═══════════════════════════════════════════════════════════════════════
# ENML — External Neural Memory Layer · Environment Configuration
# ═══════════════════════════════════════════════════════════════════════
# This file is a TEMPLATE. Copy it to `.env` and customize for your system.
#
#   cp .env.example .env
#   nano .env
#
# All values below are defaults — update paths marked with /path/to/
# ═══════════════════════════════════════════════════════════════════════

# ── Root Directories ──────────────────────────────────────────────────
# ENML_ROOT defaults to the project directory. Change only if you want
# memory stored elsewhere.
ENML_ROOT=./
MEMORY_ROOT=./memory

# ── Security ──────────────────────────────────────────────────────────
# Comma-separated absolute paths the FileTool is allowed to read/write.
# IMPORTANT: Change these to YOUR actual project directories.
ALLOWED_PATHS=/home/user/Projects,/home/user/Documents

# ── Llama.cpp Inference Server ────────────────────────────────────────
# Path to your GGUF model file (download from HuggingFace).
# Recommended: Meta-Llama-3-8B-Instruct.Q4_K_M.gguf
MODEL_PATH=/path/to/your/Meta-Llama-3-8B-Instruct.Q4_K_M.gguf

# Path to the llama-server binary (built from llama.cpp).
# Build guide: https://github.com/ggerganov/llama.cpp#build
LLAMA_SERVER=/path/to/llama.cpp/build/bin/llama-server

# URL where the llama-server listens (default port 8080).
LLAMA_SERVER_URL=http://localhost:8080

# ── Qdrant Vector Database ───────────────────────────────────────────
# URL of the Qdrant instance (Docker container managed by run_qdrant.sh).
QDRANT_URL=http://localhost:6333

# Optional API key — leave blank for local-only deployments.
QDRANT_API_KEY=

# Collection names — change only if you need custom naming.
QDRANT_KNOWLEDGE_COLLECTION=knowledge_collection
QDRANT_CONVERSATION_COLLECTION=conversation_collection
QDRANT_RESEARCH_COLLECTION=research_collection
QDRANT_PROJECT_COLLECTION=project_collection
QDRANT_PROFILE_COLLECTION=profile_collection

# ── Embedding Model ──────────────────────────────────────────────────
# SentenceTransformer model name (auto-downloaded on first run).
# Default: all-MiniLM-L6-v2 (fast, 384-dim, ~90MB)
# Alternative: all-mpnet-base-v2 (better quality, 768-dim, ~420MB)
EMBED_MODEL=all-MiniLM-L6-v2
EMBED_DIM=384

# ── System Persona ───────────────────────────────────────────────────
# Name your AI assistant (shown in chat and stored in memory).
AI_NAME=ENML Assistant

# Additional context injected into the system prompt.
AI_HINT=running on local hardware
