# ENML - Infinite Learning Core Environment

# Root Directories
ENML_ROOT=./
MEMORY_ROOT=./memory

# Allowed Security Paths for File Operations (comma separated)
ALLOWED_PATHS=/home/user/Projects,/home/user/Documents

# Llama.cpp Server Variables
MODEL_PATH=/path/to/your/Meta-Llama-3-8B-Instruct.Q4_K_M.gguf
LLAMA_SERVER=/path/to/llama.cpp/build/bin/llama-server
LLAMA_SERVER_URL=http://localhost:8080

# Qdrant Vector Data Variables
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_KNOWLEDGE_COLLECTION=knowledge_collection
QDRANT_CONVERSATION_COLLECTION=conversation_collection
QDRANT_RESEARCH_COLLECTION=research_collection
QDRANT_PROJECT_COLLECTION=project_collection

# Embedding Model
EMBED_MODEL=all-MiniLM-L6-v2
EMBED_DIM=384

# System Persona Details
AI_NAME="Jarvis"
AI_HINT="running on local hardware"
